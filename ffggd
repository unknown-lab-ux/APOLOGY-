<!-- ============================================================
     JAVASCRIPT
============================================================ -->
<script>

/* ─────────────────────────────────────────────
   CONFIGURATION
   Change RECIPIENT_NAME to the person's name.
   Everything else is already set.
───────────────────────────────────────────── */
const RECIPIENT_NAME = "Jaan"; // ← EDIT: Change to the actual name

/* ─────────────────────────────────────────────
   SET BUTTON TEXT
───────────────────────────────────────────── */
document.getElementById('wa-btn').textContent =
  `${RECIPIENT_NAME} Please Click 🥺❤️`;

/* ─────────────────────────────────────────────
   WHATSAPP BUTTON
   Auto-typed message + hardcoded number
───────────────────────────────────────────── */
function openWA() {
  const msg = encodeURIComponent(
    "Okay Baby you're forgiven 🥺 But please never do this again! " +
    "And I Love Youuuu Tooooo.... ❣️💋😘"
  );
  window.open("https://wa.me/923049622076?text=" + msg, "_blank");
}

/* ─────────────────────────────────────────────
   SCROLL PROGRESS BAR
───────────────────────────────────────────── */
const progressBar = document.getElementById('progress');
window.addEventListener('scroll', function () {
  const scrolled = window.scrollY;
  const total    = document.documentElement.scrollHeight - window.innerHeight;
  progressBar.style.width = (scrolled / total * 100) + '%';
}, { passive: true });

/* ─────────────────────────────────────────────
   TYPEWRITER EFFECT
───────────────────────────────────────────── */
const lines   = [
  "Please forgive me...",
  "I'm truly sorry... 🙏",
  "Just one more chance... 🥺",
  "Nothing feels right without you..."
];
let li = 0, ci = 0, del = false;
const twEl = document.getElementById('typewriter');

(function type() {
  const txt = lines[li];
  twEl.textContent = del ? txt.slice(0, ci - 1) : txt.slice(0, ci + 1);
  del ? ci-- : ci++;
  if (!del && ci > txt.length)  { del = true;  setTimeout(type, 2300); return; }
  if (del  && ci === 0)         { del = false; li = (li + 1) % lines.length; }
  setTimeout(type, del ? 32 : 74);
})();

/* ─────────────────────────────────────────────
   RAIN CANVAS (hero background)
───────────────────────────────────────────── */
const canvas = document.getElementById('rain-canvas');
const ctx    = canvas.getContext('2d');

function resizeC() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}
resizeC();
window.addEventListener('resize', resizeC, { passive: true });

const drops = Array.from({ length: 90 }, function () {
  return {
    x:   Math.random() * window.innerWidth,
    y:   Math.random() * window.innerHeight,
    len: 12 + Math.random() * 18,
    spd: 1.2 + Math.random() * 2.2,
    op:  0.08 + Math.random() * 0.22
  };
});

(function rain() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  drops.forEach(function (d) {
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255,20,50,' + d.op + ')';
    ctx.lineWidth   = 0.6;
    ctx.moveTo(d.x, d.y);
    ctx.lineTo(d.x + d.len * 0.18, d.y + d.len);
    ctx.stroke();
    d.y += d.spd;
    if (d.y > canvas.height + d.len) {
      d.y = -d.len;
      d.x = Math.random() * canvas.width;
    }
  });
  requestAnimationFrame(rain);
})();

/* ─────────────────────────────────────────────
   SCROLL REVEAL (general sections)
───────────────────────────────────────────── */
var revealObs = new IntersectionObserver(function (entries) {
  entries.forEach(function (e) {
    if (e.isIntersecting) { e.target.classList.add('in'); revealObs.unobserve(e.target); }
  });
}, { threshold: 0.13 });

document.querySelectorAll('.reveal').forEach(function (el) { revealObs.observe(el); });

/* ─────────────────────────────────────────────
   PROMISE CARDS — staggered slide-in
───────────────────────────────────────────── */
var promiseObs = new IntersectionObserver(function (entries) {
  entries.forEach(function (e) {
    if (e.isIntersecting) {
      var delay = parseInt(e.target.dataset.d) || 0;
      setTimeout(function () { e.target.classList.add('in'); }, delay);
      promiseObs.unobserve(e.target);
    }
  });
}, { threshold: 0.12 });

document.querySelectorAll('.p-card').forEach(function (el) { promiseObs.observe(el); });

/* ─────────────────────────────────────────────
   FLOATING HEART PARTICLES
───────────────────────────────────────────── */
var pWrap  = document.getElementById('ptcl-wrap');
var emojis = ['❤️','💔','🥺','💕','💖','💗','🙏','😭'];

function spawnPtcl() {
  var p = document.createElement('div');
  p.className   = 'ptcl';
  p.textContent = emojis[Math.floor(Math.random() * emojis.length)];
  p.style.left  = (Math.random() * 100) + '%';
  p.style.fontSize       = (0.55 + Math.random() * 0.7) + 'rem';
  p.style.animationDuration = (11 + Math.random() * 9) + 's';
  p.style.animationDelay    = (Math.random() * 2) + 's';
  pWrap.appendChild(p);
  setTimeout(function () { p.remove(); }, 22000);
}

for (var i = 0; i < 10; i++) setTimeout(spawnPtcl, i * 600);
setInterval(spawnPtcl, 1600);

</script>

